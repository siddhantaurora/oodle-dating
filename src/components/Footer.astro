---
const androidLink = "https://play.google.com/store/apps/details?id=oodle.social&hl=en_IN";
const iosLink = "https://apps.apple.com/in/app/oodle-make-friends-bff/id6445989706";
---
<footer class="bg-slate-900 border-t border-slate-800 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between gap-12 border-b border-slate-800 pb-12">
      <div class="md:w-1/3">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img class="h-10 w-auto rounded-lg" src="/app-icon.png" alt="Oodle Dating" />
          <span class="font-bold text-xl text-white tracking-tight">Oodle Dating</span>
        </a>
        <p class="text-slate-400 leading-relaxed">Meet Filipino Singles Looking for Real Love. Genuine connections built on serious relationships.</p>
      </div>
      <div class="flex flex-col gap-4 justify-center md:items-end">
        <p class="text-slate-300 font-medium text-sm">Download the App</p>
        <div class="flex gap-4">
          <a href={iosLink} target="_blank" rel="noopener noreferrer" class="bg-black border border-slate-700 hover:border-slate-500 hover:bg-slate-800 transition-all p-3 rounded-xl flex items-center gap-3">
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16.36 14c.08-.02.4-1.28 1.54-1.88-1.02-1.78-2.61-1.99-3.23-2.02-1.42-.14-2.76.84-3.51.84-.73 0-1.84-.82-2.99-.8-1.51.02-2.91.88-3.69 2.22-1.57 2.73-.4 6.78 1.13 8.98.74 1.08 1.62 2.27 2.8 2.23 1.13-.04 1.56-.73 2.92-.73s1.76.73 2.94.7c1.22-.02 1.98-1.08 2.72-2.15.86-1.25 1.22-2.45 1.23-2.52-.03-.01-2.35-.9-1.86-4.87zM14.74 7.64c.64-.78 1.07-1.85.95-2.94-1.02.04-2.19.68-2.85 1.46-.58.69-1.09 1.78-.95 2.85 1.13.09 2.21-.59 2.85-1.37z" />
            </svg>
            <div class="text-left leading-none">
              <div class="text-[10px] text-slate-300">Download on the</div>
              <div class="text-sm font-semibold text-white">App Store</div>
            </div>
          </a>
          <a href={androidLink} target="_blank" rel="noopener noreferrer" class="bg-black border border-slate-700 hover:border-slate-500 hover:bg-slate-800 transition-all p-3 rounded-xl flex items-center gap-3">
             <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 13.5l-9.5 5.5v-11l9.5 5.5z"></path></svg>
            <div class="text-left leading-none">
              <div class="text-[10px] text-slate-300">GET IT ON</div>
              <div class="text-sm font-semibold text-white">Google Play</div>
            </div>
          </a>
        </div>
      </div>
    </div>
    <div class="pt-8 flex flex-col md:flex-row justify-between items-center text-slate-500 text-sm">
      <p>&copy; {new Date().getFullYear()} Oodle Dating. All rights reserved.</p>
    </div>
  </div>
</footer>
