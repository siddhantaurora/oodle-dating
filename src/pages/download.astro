---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Download Oodle Dating" description="Redirecting to the App Store or Google Play">
  <div class="flex-grow flex items-center justify-center p-4 text-center min-h-[60vh]">
    <div class="max-w-md w-full">
      <div class="animate-pulse mb-6 flex justify-center">
        <img src="/app-icon.png" alt="Oodle Dating" class="w-20 h-20 rounded-xl shadow-lg" />
      </div>
      <h1 class="text-2xl font-bold text-slate-800 mb-2">Finding your app store...</h1>
      <p class="text-slate-500 mb-8">You should be redirected automatically.</p>
      
      <div class="flex flex-col gap-3">
        <a href="https://apps.apple.com/in/app/oodle-make-friends-bff/id6445989706" class="p-3 bg-slate-100 text-slate-700 font-semibold rounded-xl hover:bg-slate-200 transition-colors">
          Go to Apple App Store
        </a>
        <a href="https://play.google.com/store/apps/details?id=oodle.social&hl=en_IN" class="p-3 bg-slate-100 text-slate-700 font-semibold rounded-xl hover:bg-slate-200 transition-colors">
          Go to Google Play Store
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Execute redirect immediately on the client side based on user agent
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;
    const androidLink = "https://play.google.com/store/apps/details?id=oodle.social&hl=en_IN";
    const iosLink = "https://apps.apple.com/in/app/oodle-make-friends-bff/id6445989706";

    if (/android/i.test(userAgent)) {
      window.location.replace(androidLink);
    } else if (/iPad|iPhone|iPod/.test(userAgent) && !window.MSStream) {
      window.location.replace(iosLink);
    } else {
      // If desktop somehow lands here, wait 3 seconds and send them to the homepage
      setTimeout(() => {
        window.location.replace('/');
      }, 3000);
    }
  </script>
</BaseLayout>
