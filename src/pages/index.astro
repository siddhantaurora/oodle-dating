---
import BaseLayout from '../layouts/BaseLayout.astro';

const headline = "Meet Filipino Singles Looking for Real Love";
const subheadline = "Join 1,000,000+ users connecting with genuine Filipina women who are serious about relationships — not games.";
const ctaText = "View Singles Now";
const iosLink = "https://apps.apple.com/in/app/oodle-make-friends-bff/id6445989706";
const androidLink = "https://play.google.com/store/apps/details?id=oodle.social&hl=en_IN";
---
<BaseLayout title={`Oodle Dating - ${headline}`} description={subheadline}>
  
  <section class="relative bg-white overflow-hidden pt-20 pb-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
        <div class="md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left text-center">
          <div class="inline-flex items-center px-4 py-2 rounded-full border border-purple-200 bg-purple-50 text-purple-700 text-sm font-semibold mb-6 shadow-sm">
            <span class="flex h-2.5 w-2.5 rounded-full bg-blue-500 mr-2 animate-pulse"></span>
            1,000,000+ Users Worldwide
          </div>
          <h1 class="text-5xl tracking-tight font-extrabold text-slate-900 sm:text-6xl md:text-6xl lg:text-6xl mb-6">
            Meet Filipino Singles Looking for <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">Real Love</span>
          </h1>
          <p class="mt-3 text-lg text-slate-600 sm:text-xl md:mt-5 md:max-w-3xl leading-relaxed">
            {subheadline}
          </p>
          <div class="mt-10">
            <p class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-4">Download our app to view singles:</p>
            
            <!-- Universal View: Mobile and Desktop Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 sm:justify-center lg:justify-start">
              <a href={iosLink} class="w-full sm:w-auto flex items-center justify-center gap-3 px-8 py-4 border border-transparent text-lg font-bold rounded-full text-white bg-gradient-to-r from-blue-500 to-purple-600 hover:scale-105 hover:shadow-xl hover:shadow-purple-200 transition-all duration-300">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M16.36 14c.08-.02.4-1.28 1.54-1.88-1.02-1.78-2.61-1.99-3.23-2.02-1.42-.14-2.76.84-3.51.84-.73 0-1.84-.82-2.99-.8-1.51.02-2.91.88-3.69 2.22-1.57 2.73-.4 6.78 1.13 8.98.74 1.08 1.62 2.27 2.8 2.23 1.13-.04 1.56-.73 2.92-.73s1.76.73 2.94.7c1.22-.02 1.98-1.08 2.72-2.15.86-1.25 1.22-2.45 1.23-2.52-.03-.01-2.35-.9-1.86-4.87zM14.74 7.64c.64-.78 1.07-1.85.95-2.94-1.02.04-2.19.68-2.85 1.46-.58.69-1.09 1.78-.95 2.85 1.13.09 2.21-.59 2.85-1.37z" /></svg>
                Download for iPhone
              </a>
              <a href={androidLink} class="w-full sm:w-auto flex items-center justify-center gap-3 px-8 py-4 border-2 border-slate-200 text-lg font-bold rounded-full text-slate-700 bg-white hover:border-purple-300 hover:bg-purple-50 hover:scale-105 transition-all duration-300">
                <svg class="w-6 h-6 text-emerald-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.3414c-.5511 0-.9993-.4486-.9993-.9997 0-.5516.4482-1.0002.9993-1.0002.5511 0 .9997.4486.9997 1.0002 0 .5511-.4481.9997-.9997.9997m-11.046 0c-.5511 0-.9993-.4486-.9993-.9997 0-.5516.4482-1.0002.9993-1.0002.5511 0 .9997.4486.9997 1.0002 0 .5511-.4486.9997-.9997.9997m11.4045-6.02L19.18 6.0697a.499.499 0 10-.8637-.5024l-1.3503 3.3242c-1.4013-.6423-2.9997-1.0006-4.6644-1.0006-1.6642 0-3.2636.3583-4.665.1l-1.3498-3.3242a.4988.4988 0 10-.8637.5024l1.2985 3.2517C3.1352 10.3957 0 14.8573 0 20.3015h24c0-5.4442-3.1348-9.9058-6.1185-10.98z"/></svg>
                Download for Android
              </a>
            </div>

            <!-- Desktop View: QR Code Below Buttons -->
            <div class="hidden md:flex items-center gap-6 mt-8 bg-white p-4 rounded-2xl shadow-sm border border-slate-100 max-w-md ring-1 ring-slate-100/50 hover:shadow-md transition-shadow">
              <img id="qrCode" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="QR Code to install Oodle" class="w-20 h-20 rounded-lg shadow-sm" />
              <script is:inline>
                document.addEventListener('DOMContentLoaded', () => {
                  const qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + encodeURIComponent(window.location.origin + "/download");
                  document.getElementById('qrCode').src = qrUrl;
                });
              </script>
              <div>
                <h3 class="font-bold text-slate-800 text-base mb-1">Scan to Download</h3>
                <p class="text-sm text-slate-500 leading-relaxed text-left">Point your phone's camera at this code to get the app.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="mt-14 sm:mt-16 lg:mt-0 lg:col-span-6 relative z-10 w-full mb-8 lg:mb-0">
          <div class="relative rounded-[2rem] overflow-hidden shadow-2xl aspect-[4/3] group mt-8 lg:mt-0 border-8 border-white/50 ring-1 ring-slate-100">
            <div class="absolute inset-0 bg-gradient-to-tr from-purple-500/20 to-transparent mix-blend-overlay z-10"></div>
            <img class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105" src="/hero.jpg" alt="Happy couple hugging" />
          </div>
          <!-- Decorative blur elements behind the image -->
          <div class="absolute -top-12 -right-12 w-64 h-64 bg-purple-300 rounded-full mix-blend-multiply filter blur-[80px] opacity-60 pointer-events-none"></div>
          <div class="absolute -bottom-12 -left-12 w-64 h-64 bg-blue-300 rounded-full mix-blend-multiply filter blur-[80px] opacity-60 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white border-t border-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-8">
        <span class="w-8 h-1 bg-rose-500 rounded-full block"></span>
        <h2 class="text-lg font-bold text-slate-800 tracking-wide">Our Mission</h2>
        <span class="w-8 h-1 bg-rose-500 rounded-full block"></span>
      </div>
      <h3 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 leading-tight mb-8">
        We believe finding the right person can change your life.
      </h3>
      <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed font-light max-w-3xl mx-auto">
        Our mission is to make it easier for people around the world to connect, build meaningful relationships, and find something <span class="font-bold text-slate-800">real</span> — no matter where they are.
      </p>
    </div>
  </section>

</BaseLayout>
