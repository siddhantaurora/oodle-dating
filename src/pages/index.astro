---
import BaseLayout from '../layouts/BaseLayout.astro';

const iosLink = "https://apps.apple.com/app/id6445989706";
const androidLink = "https://play.google.com/store/apps/details?id=oodle.social";
---

<BaseLayout title="Oodle" description="Download the Oodle mobile application.">
  <div class="flex-grow flex flex-col items-center justify-center p-6 text-center min-h-[70vh] bg-slate-50">
    <div class="max-w-md w-full bg-white p-10 rounded-[2.5rem] shadow-xl border border-slate-100/50 flex flex-col items-center">
      <img src="/app-icon.png" alt="Oodle Logo" class="w-32 h-32 rounded-3xl shadow-lg mb-8" />
      <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Oodle</h1>
      <p class="text-slate-500 mb-10 leading-relaxed max-w-sm">Download the app to get started.</p>
      
      <div class="flex flex-col gap-4 w-full font-sans">
        <a href={iosLink} class="w-full flex items-center justify-center gap-3 px-8 py-4 border border-transparent text-lg font-bold rounded-full text-white bg-gradient-to-r from-blue-500 to-purple-600 hover:scale-[1.02] hover:shadow-lg hover:shadow-purple-100 transition-all duration-300">
          Download for iPhone
        </a>
        <a href={androidLink} class="w-full flex items-center justify-center gap-3 px-8 py-4 border-2 border-slate-200 text-lg font-bold rounded-full text-slate-700 bg-white hover:border-purple-300 hover:bg-purple-50 hover:scale-[1.02] transition-all duration-300">
          Download for Android
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
